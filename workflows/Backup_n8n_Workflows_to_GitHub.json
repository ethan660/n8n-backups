    {
      "parameters": {
        "jsCode": "const rows = $input.all().map((i) => i.json);\nconst by = (s) => rows.filter((r) => r.status === s);\nconst created = by('created');\nconst updated = by('updated');\nconst unchanged = by('unchanged');\nconst failed = by('failed');\nconst ok = failed.length === 0;\nconst stamp = $now.toFormat('yyyy-MM-dd HH:mm');\nconst line = (r) => '<li>' + r.name + ' <code>' + r.file + '</code>' + (r.error ? ' — ' + r.error : '') + '</li>';\nconst section = (title, arr) => arr.length ? ('<h3>' + title + ' (' + arr.length + ')</h3><ul>' + arr.map(line).join('') + '</ul>') : '';\nconst subject = (ok ? '✅' : '⚠️') + ' n8n backup ' + (ok ? 'succeeded' : 'had failures') + ' — ' + stamp;\nconst html = [\n  '<h2>n8n → GitHub backup</h2>',\n  '<p><b>' + rows.length + '</b> workflows processed at ' + stamp + '.</p>',\n  '<p>Created: ' + created.length + ' · Updated: ' + updated.length + ' · Unchanged: ' + unchanged.length + ' · Failed: ' + failed.length + '</p>',\n  section('Failed', failed),\n  section('Created', created),\n  section('Updated', updated),\n  section('Unchanged', unchanged),\n].join('');\nreturn [{ json: { subject, html, ok, total: rows.length, created: created.length, updated: updated.length, unchanged: unchanged.length, failed: failed.length } }];"
      },
