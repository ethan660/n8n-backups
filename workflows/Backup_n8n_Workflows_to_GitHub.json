    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const gh = $json;\nconst prep = $('Prepare Files').item.json;\nconst existing = gh.content ? Buffer.from(gh.content, 'base64').toString('utf8') : '';\nconst changed = existing.trim() !== String(prep.content).trim();\nreturn {\n  json: {\n    changed,\n    name: prep.name,\n    fileName: prep.fileName,\n    filePath: prep.filePath,\n    newContent: prep.content,\n  },\n};"
      },
