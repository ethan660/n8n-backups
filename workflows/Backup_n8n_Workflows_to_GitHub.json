    {
      "parameters": {
        "jsCode": "const items = $input.all();\nreturn items.map((item) => {\n  const wf = item.json;\n  const base = (wf.name || ('workflow_' + wf.id))\n    .replace(/[^a-zA-Z0-9-_ ]/g, '_')\n    .replace(/\\s+/g, '_')\n    .replace(/_+/g, '_')\n    .replace(/^_+|_+$/g, '');\n  const fileName = base + '.json';\n  return {\n    json: {\n      name: wf.name || String(wf.id),\n      fileName,\n      filePath: 'workflows/' + fileName,\n      content: JSON.stringify(wf, null, 2),\n    },\n  };\n});"
      },
