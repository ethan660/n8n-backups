      "id": "05612014-4e31-443b-87ac-08f8eb57be3c",
      "name": "HTTP gemini-2.2",
      "retryOnFail": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst toStr = (v) => (v == null ? '' : String(v).trim());\n\nconst collectPrompts = () => {\n  const out = [];\n  for (const it of items) {\n    // 1. 定位 Gemini 返回的核心文本\n    const text = it.json?.candidates?.[0]?.content?.parts?.[0]?.text;\n    let s = toStr(text);\n\n    if (s) {\n      // 2. 移除开头的 Markdown JSON 标记和方括号\n      s = s.replace(/^```json\\s*\\[?\\n?/, '') \n           .replace(/\\n?\\]?\\s*```$/, '')      \n           .trim();\n\n      // 3. 彻底清除换行符和各种斜杠\n      s = s.replace(/\\\\n/g, ' ')   // 清理转义换行\n           .replace(/\\n/g, ' ')     // 清理常规换行\n           .replace(/\\/n/g, ' ')    // 清理正斜杠换行\n           .replace(/\\\\/g, '')      // 移除所有反斜杠 \\\n           .replace(/\\//g, ' ');    // 移除所有正斜杠 / (替换为空格以防单词粘连)\n\n      // 4. 清理残留的引号标记（可选，如果 AI 输出带引号的话）\n      s = s.replace(/\\\"/g, '');\n\n      // 5. 压缩多余空格\n      s = s.replace(/\\s+/g, ' ').trim();\n\n      out.push(s);\n    }\n  }\n  return Array.from(new Set(out));\n};\n\nconst prompts = collectPrompts();\n\n// 最终输出\nreturn [{\n  json: {\n    prompt: prompts[0] || \"\" \n  }\n}];"
      },
